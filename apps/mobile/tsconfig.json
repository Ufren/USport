{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-native",
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@usport/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "index.ts", "App.tsx"],
  "exclude": ["node_modules", "android", "ios"]
}
