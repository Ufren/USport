{
  "name": "@usport/mini-program",
  "version": "1.0.0",
  "private": true,
  "description": "USport WeChat Mini Program",
  "scripts": {
    "dev": "tsc --watch --noEmit --preserveWatchOutput",
    "build": "pnpm run typecheck",
    "typecheck": "tsc --noEmit",
