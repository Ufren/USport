<view class="container">
  <view class="logo-section">
    <image class="logo" src="/assets/images/logo.png" mode="aspectFit" />
    <text class="app-name">USport</text>
    <text class="slogan">运动健身，共享场馆</text>
  </view>

  <view class="login-section">
    <button class="wechat-btn" type="primary" bindtap="onWechatLogin">
      <image class="wechat-icon" src="/assets/images/wechat.png" mode="aspectFit" />
      <text>微信一键登录</text>
    </button>

    <button class="phone-btn" type="default" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      <text>使用手机号登录</text>
    </button>

    <view class="tips">
      <text class="tip">登录即表示同意</text>
      <text class="link">《用户协议》</text>
      <text class="tip">和</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>
</view>
