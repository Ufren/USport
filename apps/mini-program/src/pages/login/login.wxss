.container {
  min-height: 100vh;
  background-color: #fff;
  padding: 100rpx 60rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 40rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #1890ff;
  margin-top: 20rpx;
}

.form-section {
  width: 100%;
}

.input-group {
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  height: 90rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
}

.login-btn[disabled] {
  background-color: #ccc;
}

.actions {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
}

.link {
  font-size: 26rpx;
  color: #1890ff;
}
