.my-activities-page {
  gap: 24rpx;
  padding: 24rpx 24rpx 48rpx;
}

.hero-card,
.loading-card,
.empty-card,
.activity-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.hero-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 248, 255, 0.94) 100%);
}

.hero-eyebrow {
  color: #0a84ff;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title,
.toolbar-title,
.empty-title,
.activity-title {
  color: #111111;
  font-weight: 800;
}

.hero-title {
  font-size: 42rpx;
  line-height: 1.3;
}

.hero-subtitle,
.loading-text,
.empty-text,
.activity-subtitle,
.meta-text,
.footer-hint {
  color: rgba(17, 17, 17, 0.68);
  font-size: 24rpx;
  line-height: 1.65;
}

.filter-row,
.toolbar,
.activity-top,
.activity-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.filter-row {
  flex-wrap: wrap;
}

.filter-chip {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  background: rgba(255, 255, 255, 0.9);
  color: rgba(17, 17, 17, 0.74);
  font-size: 24rpx;
  font-weight: 700;
}

.filter-chip--active {
  border-color: #0a84ff;
  background: #eaf2ff;
  color: #0a84ff;
}

.filter-chip--pressed,
.activity-card--pressed {
  transform: scale(0.985);
  opacity: 0.94;
}

.toolbar-btn,
.empty-btn,
.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.toolbar-btn,
.empty-btn {
  background: #0a84ff;
  color: #ffffff;
}

.ghost-btn {
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  background: rgba(255, 255, 255, 0.92);
  color: #111111;
}

.activity-list,
.meta-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.official-badge {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #0a84ff;
  font-size: 20rpx;
  font-weight: 700;
}

.status-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(10, 132, 255, 0.1);
  color: #0a84ff;
  font-size: 20rpx;
  font-weight: 700;
}
