.create-page {
  gap: 24rpx;
  padding: 24rpx 24rpx 140rpx;
}

.create-hero,
.preview-card,
.form-section,
.field-card,
.stepper-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.create-hero {
  padding: 8rpx 0 4rpx;
}

.hero-eyebrow,
.preview-label {
  color: #0a84ff;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  color: #111111;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-subtitle,
.section-subtitle,
.option-description,
.preview-meta,
.field-error {
  color: rgba(17, 17, 17, 0.68);
  font-size: 24rpx;
  line-height: 1.65;
}

.preview-risk,
.field-error {
  color: #ff3b30;
}

.preview-card,
.form-section {
  padding: 28rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.preview-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 248, 255, 0.94) 100%);
}

.preview-title,
.section-title,
.field-label {
  color: #111111;
}

.preview-title,
.section-title {
  font-size: 34rpx;
  font-weight: 800;
}

.field-label {
  font-size: 26rpx;
  font-weight: 700;
}

.section-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option-chip,
.mini-chip,
.field-card,
.stepper-card {
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  border-radius: 24rpx;
}

.option-chip {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
  min-width: 280rpx;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.88);
}

.option-chip--active {
  border-color: #0a84ff;
  background: #eaf2ff;
}

.option-chip--pressed,
.mini-chip--pressed {
  transform: scale(0.98);
  opacity: 0.92;
}

.option-title {
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
}

.mini-chip {
  padding: 16rpx 22rpx;
  background: rgba(255, 255, 255, 0.88);
  color: rgba(17, 17, 17, 0.76);
  font-size: 24rpx;
  font-weight: 700;
}

.mini-chip--active {
  border-color: #0a84ff;
  background: #eaf2ff;
  color: #0a84ff;
}

.field-card,
.stepper-card {
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.92);
}

.text-input,
.text-area,
.picker-field {
  width: 100%;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.6;
}

.text-input,
.picker-field {
  min-height: 48rpx;
}

.text-area {
  min-height: 200rpx;
}

.time-grid {
  display: flex;
  gap: 16rpx;
}

.field-card--half {
  flex: 1;
}

.stepper-row,
.stepper {
  display: flex;
  align-items: center;
}

.stepper-row {
  justify-content: space-between;
}

.stepper {
  gap: 16rpx;
}

.stepper-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #0a84ff;
  font-size: 30rpx;
  font-weight: 700;
}

.stepper-value {
  min-width: 48rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}

.form-section--compact {
  gap: 20rpx;
}

.submit-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(245, 245, 247, 0.94);
  border-top: 1rpx solid rgba(60, 60, 67, 0.1);
  backdrop-filter: blur(16rpx);
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 999rpx;
  background: #0a84ff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}
