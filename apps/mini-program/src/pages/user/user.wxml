<view class="container">
  <view class="user-header">
    <image class="avatar" src="{{userInfo.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || userInfo.phone || userInfo.openid || '游客'}}</text>
      <text class="username">@{{userInfo.phone || userInfo.openid || 'guest'}}</text>
    </view>
    <button class="edit-btn" size="mini" bindtap="onEditProfile">编辑</button>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="onMenuClick" data-type="orders">
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onMenuClick" data-type="venues">
      <text class="menu-text">我的场馆</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onMenuClick" data-type="activities">
      <text class="menu-text">我的活动</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onMenuClick" data-type="settings">
      <text class="menu-text">设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <button class="logout-btn" type="warn" bindtap="onLogout">退出登录</button>
</view>
