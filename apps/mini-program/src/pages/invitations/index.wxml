<view class="container invitations-page">
  <view class="hero-card">
    <text class="hero-eyebrow">USport / 我的邀约</text>
    <text class="hero-title">把值得优先回应的邀约和消息收进同一个工作区</text>
    <text class="hero-subtitle">邀约不是泛聊天入口，而是成局前最有价值的行动信号。</text>

    <view class="hero-metrics">
      <view class="metric-card">
        <text class="metric-value">{{pendingCount}}</text>
        <text class="metric-label">待处理邀约</text>
      </view>
      <view class="metric-card">
        <text class="metric-value">{{messages.length}}</text>
        <text class="metric-label">消息预览</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!isLoggedIn}}" class="empty-card">
    <text class="empty-title">登录后查看你的邀约工作区</text>
    <text class="empty-text">接受邀约、追踪报名进度和查看活动更新，都会集中出现在这里。</text>
    <button class="primary-btn" bindtap="onGoLogin">去登录</button>
  </view>

  <view wx:elif="{{loading}}" class="loading-card">
    <text class="loading-text">正在同步邀约和消息...</text>
  </view>

  <block wx:else>
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">待处理邀约</text>
        <text class="section-subtitle">先处理未回应邀约，再决定是否继续安排本周运动节奏。</text>
      </view>

      <view wx:if="{{invitations.length === 0}}" class="empty-inline">
        <text class="empty-inline-title">还没有新的邀约</text>
        <text class="empty-inline-text">后续别人邀请你加入活动时，会第一时间出现在这里。</text>
      </view>

      <view wx:else class="card-list">
        <view
          class="invite-card"
          wx:for="{{invitations}}"
          wx:key="id"
          bindtap="onInvitationTap"
          data-activity-id="{{item.activityId}}"
        >
          <view class="card-top">
            <view class="card-copy">
              <text class="card-title">{{item.activityTitle}}</text>
              <text class="card-meta">{{item.venueLabel}}</text>
            </view>
            <text class="status-badge">{{item.statusLabel}}</text>
          </view>

          <text class="card-message">{{item.message}}</text>
          <text class="card-meta">{{item.senderName}} · {{item.senderBadge}}</text>
          <text class="card-meta">{{item.activityTime}} · {{item.participantHint}}</text>
          <text class="card-meta">{{item.createdAtLabel}}</text>

          <view wx:if="{{item.canAccept || item.canDecline}}" class="action-row">
            <button
              wx:if="{{item.canDecline}}"
              class="ghost-btn"
              size="mini"
              catchtap="onRespondTap"
              data-id="{{item.id}}"
              data-action="decline"
            >
              婉拒
            </button>
            <button
              wx:if="{{item.canAccept}}"
              class="primary-btn"
              size="mini"
              catchtap="onRespondTap"
              data-id="{{item.id}}"
              data-action="accept"
            >
              接受邀约
            </button>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">消息预览</text>
        <text class="section-subtitle">把报名更新、邀约回执和活动提醒先集中看一遍。</text>
      </view>

      <view wx:if="{{messages.length === 0}}" class="empty-inline">
        <text class="empty-inline-title">还没有新的消息</text>
        <text class="empty-inline-text">邀约状态变化和活动进度更新会同步到这里。</text>
      </view>

      <view wx:else class="card-list">
        <view
          class="message-card"
          wx:for="{{messages}}"
          wx:key="id"
          bindtap="onMessageTap"
          data-id="{{item.id}}"
        >
          <view class="card-top">
            <text class="card-title">{{item.title}}</text>
            <text class="message-time">{{item.timestampLabel}}</text>
          </view>
          <text class="card-message">{{item.preview}}</text>
          <view wx:if="{{item.unreadCount > 0}}" class="message-badge">
            {{item.unreadCount}} 条未读
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
