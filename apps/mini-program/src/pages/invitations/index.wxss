.invitations-page {
  gap: 24rpx;
  padding: 24rpx 24rpx 56rpx;
  background: linear-gradient(180deg, #f7f7fa 0%, #f1f2f6 100%);
}

.hero-card,
.section-card,
.empty-card,
.loading-card,
.invite-card,
.message-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.08);
}

.hero-card {
  background: rgba(255, 255, 255, 0.84);
  backdrop-filter: blur(18rpx);
}

.hero-eyebrow,
.metric-label,
.message-badge {
  color: rgba(17, 17, 17, 0.48);
  font-size: 22rpx;
  font-weight: 700;
}

.message-time {
  color: rgba(17, 17, 17, 0.46);
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title,
.section-title,
.empty-title,
.empty-inline-title,
.card-title,
.metric-value {
  color: #111111;
  font-weight: 800;
}

.hero-title {
  font-size: 42rpx;
  line-height: 1.3;
}

.hero-subtitle,
.section-subtitle,
.empty-text,
.empty-inline-text,
.loading-text,
.card-message,
.card-meta {
  color: rgba(17, 17, 17, 0.56);
  font-size: 24rpx;
  line-height: 1.6;
}

.hero-metrics,
.card-top,
.action-row {
  display: flex;
  gap: 16rpx;
}

.metric-card {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(238, 240, 244, 0.95);
}

.metric-value {
  font-size: 36rpx;
}

.section-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-top {
  align-items: flex-start;
  justify-content: space-between;
}

.card-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.status-badge,
.message-badge {
  align-self: flex-start;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(10, 132, 255, 0.1);
  color: #0a84ff;
}

.primary-btn,
.ghost-btn {
  display: flex;
  min-width: 180rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.primary-btn {
  background: #0a84ff;
  color: #ffffff;
}

.ghost-btn {
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  background: rgba(255, 255, 255, 0.9);
  color: #111111;
}

.card-hover {
  transform: scale(0.985);
  opacity: 0.94;
}
