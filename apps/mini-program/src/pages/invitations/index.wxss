.invitations-page {
  gap: 24rpx;
  padding: 24rpx 24rpx 48rpx;
}

.hero-card,
.section-card,
.empty-card,
.loading-card,
.invite-card,
.message-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid #dce2dd;
  background: #ffffff;
}

.hero-card {
  background: linear-gradient(180deg, #edf3ea 0%, #ffffff 100%);
}

.hero-eyebrow,
.metric-label,
.message-time,
.message-badge {
  color: #156b52;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title,
.section-title,
.empty-title,
.empty-inline-title,
.card-title,
.metric-value {
  color: #131714;
  font-weight: 800;
}

.hero-title {
  font-size: 42rpx;
  line-height: 1.3;
}

.hero-subtitle,
.section-subtitle,
.empty-text,
.empty-inline-text,
.loading-text,
.card-message,
.card-meta {
  color: #66726c;
  font-size: 24rpx;
  line-height: 1.6;
}

.hero-metrics,
.card-top,
.action-row {
  display: flex;
  gap: 16rpx;
}

.hero-metrics {
  margin-top: 8rpx;
}

.metric-card {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(21, 107, 82, 0.06);
}

.metric-value {
  font-size: 36rpx;
}

.section-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-top {
  align-items: flex-start;
  justify-content: space-between;
}

.card-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.status-badge,
.message-badge {
  align-self: flex-start;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf3ea;
}

.message-time {
  color: #66726c;
}

.primary-btn,
.ghost-btn {
  display: flex;
  min-width: 180rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-btn {
  background: #156b52;
  color: #ffffff;
}

.ghost-btn {
  border: 1rpx solid #dce2dd;
  background: #ffffff;
  color: #131714;
}
