.profile-page {
  gap: 24rpx;
  padding: 28rpx 24rpx 56rpx;
  background: linear-gradient(180deg, #f7f7fa 0%, #f1f2f6 100%);
}

.profile-card,
.profile-metric-card,
.menu-item {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.08);
}

.profile-card {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 30rpx;
  align-items: center;
}

.profile-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: #0a84ff;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
}

.profile-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.profile-name {
  color: #111111;
  font-size: 34rpx;
  font-weight: 800;
}

.profile-handle {
  color: rgba(17, 17, 17, 0.72);
  font-size: 24rpx;
  font-weight: 600;
}

.profile-hint {
  color: rgba(17, 17, 17, 0.48);
  font-size: 22rpx;
  line-height: 1.5;
}

.profile-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  min-height: 64rpx;
  border-radius: 999rpx;
  background: #0a84ff;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.profile-metric-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.profile-metric-card {
  display: flex;
  gap: 8rpx;
  padding: 28rpx;
}

.profile-metric-value {
  color: #111111;
  font-size: 42rpx;
  font-weight: 800;
}

.profile-metric-label {
  color: rgba(17, 17, 17, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}

.profile-metric-hint,
.section-subtitle,
.menu-description {
  color: rgba(17, 17, 17, 0.48);
  font-size: 22rpx;
  line-height: 1.5;
}

.menu-section {
  display: flex;
  gap: 16rpx;
}

.section-header {
  display: flex;
  gap: 8rpx;
}

.section-title {
  color: #111111;
  font-size: 34rpx;
  font-weight: 800;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
}

.menu-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.menu-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.menu-title {
  color: #111111;
  font-size: 28rpx;
  font-weight: 800;
}

.menu-badge {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 159, 10, 0.12);
  color: #ff9f0a;
  font-size: 20rpx;
  font-weight: 800;
}

.menu-arrow {
  color: rgba(17, 17, 17, 0.32);
  font-size: 40rpx;
}

.logout-btn {
  margin-top: 12rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.92);
  color: #ff3b30;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  font-weight: 800;
}

.item-hover {
  transform: scale(0.985);
  opacity: 0.94;
}
