.profile-page {
  gap: 24rpx;
  padding: 28rpx 24rpx 48rpx;
}

.profile-card,
.profile-metric-card,
.menu-item {
  background: #ffffff;
  border: 1rpx solid #dce2dd;
  border-radius: 28rpx;
}

.profile-card {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 28rpx;
  align-items: center;
}

.profile-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: #156b52;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
}

.profile-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.profile-name {
  color: #131714;
  font-size: 34rpx;
  font-weight: 800;
}

.profile-handle {
  color: #2d3631;
  font-size: 24rpx;
  font-weight: 600;
}

.profile-hint {
  color: #66726c;
  font-size: 22rpx;
  line-height: 1.5;
}

.profile-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  min-height: 64rpx;
  border-radius: 999rpx;
  background: #156b52;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.profile-metric-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.profile-metric-card {
  display: flex;
  gap: 8rpx;
  padding: 28rpx;
}

.profile-metric-value {
  color: #131714;
  font-size: 42rpx;
  font-weight: 800;
}

.profile-metric-label {
  color: #2d3631;
  font-size: 24rpx;
  font-weight: 700;
}

.profile-metric-hint,
.section-subtitle,
.menu-description {
  color: #66726c;
  font-size: 22rpx;
  line-height: 1.5;
}

.menu-section {
  display: flex;
  gap: 16rpx;
}

.section-header {
  display: flex;
  gap: 8rpx;
}

.section-title {
  color: #131714;
  font-size: 34rpx;
  font-weight: 800;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
}

.menu-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.menu-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.menu-title {
  color: #131714;
  font-size: 28rpx;
  font-weight: 700;
}

.menu-badge {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #fff4d8;
  color: #e6a019;
  font-size: 20rpx;
  font-weight: 700;
}

.menu-arrow {
  color: #66726c;
  font-size: 36rpx;
}

.logout-btn {
  margin-top: 12rpx;
  border-radius: 999rpx;
  background-color: #d64545;
  color: #ffffff;
}
