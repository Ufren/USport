.membership-page {
  gap: 24rpx;
  padding: 24rpx 24rpx 48rpx;
}

.hero-card,
.summary-card,
.section-card,
.plan-card,
.list-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid #dce2dd;
  background: #ffffff;
}

.hero-card {
  background: linear-gradient(180deg, #edf3ea 0%, #ffffff 100%);
}

.hero-eyebrow,
.summary-badge,
.list-status {
  color: #156b52;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title,
.section-title,
.summary-title,
.plan-title,
.list-title,
.plan-price {
  color: #131714;
  font-weight: 800;
}

.hero-title {
  font-size: 42rpx;
  line-height: 1.3;
}

.hero-subtitle,
.summary-hint,
.summary-meta,
.section-subtitle,
.plan-description,
.list-copy,
.list-time,
.summary-list-item,
.benefit-item {
  color: #66726c;
  font-size: 24rpx;
  line-height: 1.6;
}

.plan-price {
  font-size: 40rpx;
}

.section-header,
.list,
.summary-list,
.benefit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.list-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 16rpx;
}

.submit-btn {
  border-radius: 999rpx;
  background: #156b52;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}
