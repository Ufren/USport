.membership-page {
  gap: 24rpx;
  padding: 24rpx 24rpx 56rpx;
}

.hero-card,
.summary-card,
.section-card,
.plan-card,
.list-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.hero-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 248, 255, 0.94) 100%);
}

.hero-eyebrow,
.summary-badge,
.summary-pill-text,
.list-status {
  color: #0a84ff;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title,
.section-title,
.summary-title,
.plan-title,
.list-title,
.plan-price {
  color: #111111;
  font-weight: 800;
}

.hero-title {
  font-size: 42rpx;
  line-height: 1.3;
}

.hero-subtitle,
.summary-hint,
.summary-meta,
.section-subtitle,
.plan-description,
.plan-duration,
.list-copy,
.list-time,
.summary-list-item,
.benefit-item {
  color: rgba(17, 17, 17, 0.7);
  font-size: 24rpx;
  line-height: 1.65;
}

.summary-top,
.plan-top,
.list-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-main,
.plan-main,
.summary-list,
.benefit-list,
.section-header,
.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-pill {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
}

.plan-price {
  font-size: 40rpx;
}

.submit-btn,
.secondary-btn {
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.submit-btn {
  background: #0a84ff;
  color: #ffffff;
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.92);
  color: #0a84ff;
  border: 1rpx solid rgba(10, 132, 255, 0.28);
}
