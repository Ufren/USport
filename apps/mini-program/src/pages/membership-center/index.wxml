<view class="container membership-page">
  <view class="hero-card">
    <text class="hero-eyebrow">USport / 会员中心</text>
    <text class="hero-title">把曝光、推荐和高阶筛选集中为一套稳定权益</text>
    <text class="hero-subtitle">
      会员面向高频组局和长期找搭子的用户，帮助他们更高效地成局、复约和沉淀关系。
    </text>
  </view>

  <view wx:if="{{summary}}" class="summary-card">
    <text class="summary-badge">{{summary.isMember ? '会员有效中' : '未开通会员'}}</text>
    <text class="summary-title">{{summary.planName || '标准账户'}}</text>
    <text class="summary-hint">{{summary.statusLabel}}</text>
    <text wx:if="{{summary.expireAtLabel}}" class="summary-meta">
      有效期至 {{summary.expireAtLabel}}
    </text>
    <view class="summary-list">
      <text class="summary-list-item">{{summary.exposureBoost}}</text>
      <text class="summary-list-item">{{summary.filterUnlocks}}</text>
      <text class="summary-list-item">{{summary.recommendationPriority}}</text>
    </view>
  </view>

  <view class="section-card">
    <view class="section-header">
      <text class="section-title">可选套餐</text>
      <text class="section-subtitle">先把少量但明确的权益打磨清楚，再逐步丰富。</text>
    </view>
    <view class="list">
      <view wx:for="{{plans}}" wx:key="code" class="plan-card">
        <text class="plan-title">{{item.name}}</text>
        <text class="plan-price">{{item.priceLabel}}</text>
        <text class="plan-description">{{item.description}}</text>
        <view class="benefit-list">
          <text wx:for="{{item.benefits}}" wx:key="*this" class="benefit-item">
            • {{item}}
          </text>
        </view>
        <button
          class="submit-btn"
          bindtap="onPurchase"
          data-code="{{item.code}}"
          loading="{{purchasingCode === item.code}}"
          disabled="{{purchasingCode !== ''}}"
        >
          立即开通
        </button>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-header">
      <text class="section-title">最近订单</text>
      <text class="section-subtitle">让用户能清楚看到自己的付费记录。</text>
    </view>
    <view wx:if="{{orders.length > 0}}" class="list">
      <view wx:for="{{orders}}" wx:key="id" class="list-card">
        <view class="list-top">
          <text class="list-title">{{item.planCode}}</text>
          <text class="list-status">{{item.statusLabel}}</text>
        </view>
        <text class="list-copy">{{item.amountLabel}}</text>
        <text class="list-time">{{item.createdAt}}</text>
      </view>
    </view>
    <view wx:else class="list-card">
      <text class="list-copy">你还没有会员订单记录。</text>
    </view>
  </view>
</view>
