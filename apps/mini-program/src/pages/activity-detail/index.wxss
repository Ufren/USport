.detail-page {
  gap: 24rpx;
  padding: 0 24rpx 220rpx;
  background: linear-gradient(180deg, #f7f7fa 0%, #f1f2f6 100%);
}

.detail-hero {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin: 24rpx 0 0;
  padding: 34rpx 30rpx 38rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  box-shadow: 0 22rpx 48rpx rgba(15, 23, 42, 0.1);
  backdrop-filter: blur(18rpx);
}

.hero-top,
.info-row,
.rule-item,
.host-row,
.bottom-actions {
  display: flex;
}

.hero-top,
.info-row,
.rule-item {
  justify-content: space-between;
  gap: 20rpx;
}

.hero-eyebrow,
.hero-cover-label {
  color: rgba(17, 17, 17, 0.46);
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  color: #111111;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-subtitle,
.risk-hint {
  color: rgba(17, 17, 17, 0.72);
  font-size: 26rpx;
  line-height: 1.6;
}

.risk-hint {
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(10, 132, 255, 0.08);
  color: #0a84ff;
}

.status-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.status-pill--success {
  background: rgba(52, 199, 89, 0.14);
  color: #34c759;
}

.status-pill--warning {
  background: rgba(255, 159, 10, 0.14);
  color: #ff9f0a;
}

.status-pill--neutral,
.status-pill--danger {
  background: rgba(238, 240, 244, 0.95);
  color: rgba(17, 17, 17, 0.72);
}

.content-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-card,
.host-card,
.description-card,
.notice-card,
.empty-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.08);
}

.section-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-title,
.empty-title {
  color: #111111;
  font-size: 34rpx;
  font-weight: 800;
}

.section-subtitle,
.info-label,
.host-meta,
.description-text,
.notice-text,
.bottom-helper,
.empty-text {
  color: rgba(17, 17, 17, 0.48);
  font-size: 24rpx;
  line-height: 1.6;
}

.info-list,
.rule-list,
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.info-label,
.rule-label {
  flex: 0 0 160rpx;
}

.info-value,
.rule-value {
  flex: 1;
  color: #111111;
  font-size: 24rpx;
  line-height: 1.6;
  text-align: right;
}

.host-row {
  align-items: center;
  gap: 18rpx;
}

.host-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #0a84ff;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
}

.host-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.host-name {
  color: #111111;
  font-size: 30rpx;
  font-weight: 700;
}

.host-badge {
  color: #0a84ff;
  font-size: 22rpx;
  font-weight: 700;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(238, 240, 244, 0.92);
  color: rgba(17, 17, 17, 0.72);
  font-size: 22rpx;
  font-weight: 700;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.notice-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #0a84ff;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(245, 245, 247, 0.92);
  backdrop-filter: blur(18rpx);
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
}

.bottom-actions {
  gap: 16rpx;
}

.primary-btn,
.secondary-btn {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.primary-btn {
  background: #0a84ff;
  color: #ffffff;
}

.primary-btn[disabled] {
  background: rgba(60, 60, 67, 0.24);
  color: #ffffff;
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  color: #111111;
}
