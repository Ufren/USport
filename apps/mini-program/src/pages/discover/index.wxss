.discover-page {
  gap: 32rpx;
  padding: 32rpx 24rpx 48rpx;
}

.hero-panel {
  display: flex;
  gap: 20rpx;
}

.hero-eyebrow {
  color: #156b52;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-title {
  color: #131714;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-subtitle {
  color: #2d3631;
  font-size: 28rpx;
  line-height: 1.6;
}

.metric-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.metric-card {
  display: flex;
  gap: 8rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid #dce2dd;
  border-radius: 28rpx;
}

.metric-value {
  color: #131714;
  font-size: 42rpx;
  font-weight: 800;
}

.metric-label {
  color: #2d3631;
  font-size: 24rpx;
  font-weight: 700;
}

.metric-hint {
  color: #66726c;
  font-size: 22rpx;
  line-height: 1.5;
}

.featured-card {
  display: flex;
  gap: 18rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  background: #156b52;
  box-shadow: 0 18rpx 36rpx rgba(19, 23, 20, 0.12);
}

.featured-top,
.featured-footer,
.activity-item-top,
.activity-footer,
.section-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.featured-top {
  align-items: center;
}

.featured-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(232, 247, 239, 0.18);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.featured-sport {
  color: #b6f36a;
  font-size: 22rpx;
  font-weight: 700;
}

.featured-title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.3;
}

.featured-subtitle,
.featured-meta,
.featured-host-badge {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 1.5;
}

.featured-tag-list,
.venue-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.featured-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  font-size: 20rpx;
}

.featured-footer {
  align-items: flex-end;
}

.featured-host {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.featured-host-name {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.featured-cta {
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #b6f36a;
  color: #131714;
  font-size: 24rpx;
  font-weight: 700;
}

.section {
  display: flex;
  gap: 18rpx;
}

.section-title {
  color: #131714;
  font-size: 36rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #66726c;
  font-size: 24rpx;
  line-height: 1.5;
}

.filter-scroll,
.venue-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-row,
.venue-row {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 24rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 26rpx;
  border: 1rpx solid #dce2dd;
  border-radius: 999rpx;
  background: #ffffff;
  color: #2d3631;
  font-size: 24rpx;
  font-weight: 700;
}

.filter-chip--active {
  background: #b6f36a;
  border-color: #b6f36a;
  color: #131714;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-item,
.venue-card {
  display: flex;
  gap: 16rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid #dce2dd;
  border-radius: 28rpx;
}

.activity-item-top {
  align-items: flex-start;
}

.activity-title {
  color: #131714;
  font-size: 32rpx;
  font-weight: 700;
}

.activity-subtitle,
.activity-meta,
.activity-attendance,
.venue-meta,
.venue-vibe {
  color: #66726c;
  font-size: 24rpx;
  line-height: 1.5;
}

.activity-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e8f7ef;
  color: #1f9d61;
  font-size: 20rpx;
  font-weight: 700;
}

.activity-status--warning {
  background: #fff4d8;
  color: #e6a019;
}

.activity-footer {
  align-items: center;
}

.activity-action {
  color: #156b52;
  font-size: 24rpx;
  font-weight: 700;
}

.venue-card {
  width: 460rpx;
  padding: 0;
  overflow: hidden;
}

.venue-cover {
  display: flex;
  gap: 8rpx;
  padding: 28rpx;
  background: #edf3ea;
}

.venue-name {
  color: #131714;
  font-size: 30rpx;
  font-weight: 700;
}

.venue-surface {
  color: #156b52;
  font-size: 22rpx;
  font-weight: 700;
}

.venue-body {
  display: flex;
  gap: 14rpx;
  padding: 28rpx;
}

.venue-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f4f7f2;
  color: #2d3631;
  font-size: 20rpx;
}
