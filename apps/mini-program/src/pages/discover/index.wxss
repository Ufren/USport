.discover-page {
  gap: 32rpx;
  padding: 24rpx 24rpx 56rpx;
  background: linear-gradient(180deg, #f7f7fa 0%, #f1f2f6 100%);
}

.hero-panel {
  display: flex;
  gap: 20rpx;
  padding: 32rpx 28rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(18rpx);
}

.hero-eyebrow {
  color: rgba(17, 17, 17, 0.46);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-title {
  color: #111111;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-subtitle {
  color: rgba(17, 17, 17, 0.72);
  font-size: 27rpx;
  line-height: 1.6;
}

.metric-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.metric-card {
  display: flex;
  gap: 8rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(60, 60, 67, 0.08);
  border-radius: 30rpx;
}

.metric-value {
  color: #111111;
  font-size: 42rpx;
  font-weight: 800;
}

.metric-label {
  color: rgba(17, 17, 17, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}

.metric-hint {
  color: rgba(17, 17, 17, 0.46);
  font-size: 22rpx;
  line-height: 1.5;
}

.featured-card {
  display: flex;
  gap: 18rpx;
  padding: 30rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(249, 250, 252, 0.96) 100%);
  border: 1rpx solid rgba(60, 60, 67, 0.1);
  box-shadow: 0 22rpx 48rpx rgba(15, 23, 42, 0.1);
}

.featured-top,
.featured-footer,
.activity-item-top,
.activity-footer,
.section-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.featured-top {
  align-items: center;
}

.featured-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(52, 199, 89, 0.12);
  color: #34c759;
  font-size: 20rpx;
  font-weight: 700;
}

.featured-sport {
  color: #0a84ff;
  font-size: 22rpx;
  font-weight: 700;
}

.featured-title {
  color: #111111;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.3;
}

.featured-subtitle,
.featured-meta,
.featured-host-badge {
  color: rgba(17, 17, 17, 0.56);
  font-size: 24rpx;
  line-height: 1.5;
}

.featured-tag-list,
.venue-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.featured-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(238, 240, 244, 0.95);
  color: rgba(17, 17, 17, 0.72);
  font-size: 20rpx;
}

.featured-footer {
  align-items: flex-end;
}

.featured-host {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.featured-host-name {
  color: #111111;
  font-size: 30rpx;
  font-weight: 700;
}

.featured-cta {
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #0a84ff;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.section {
  display: flex;
  gap: 18rpx;
}

.section-title {
  color: #111111;
  font-size: 36rpx;
  font-weight: 800;
}

.section-subtitle {
  color: rgba(17, 17, 17, 0.46);
  font-size: 24rpx;
  line-height: 1.5;
}

.filter-scroll,
.venue-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-row,
.venue-row {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 24rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 26rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: rgba(17, 17, 17, 0.72);
  font-size: 24rpx;
  font-weight: 700;
  transition: all 160ms ease;
}

.filter-chip--active {
  background: #111111;
  border-color: #111111;
  color: #ffffff;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-item,
.venue-card {
  display: flex;
  gap: 16rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.08);
  transition: transform 160ms ease, opacity 160ms ease;
}

.activity-item-top {
  align-items: flex-start;
}

.activity-title {
  color: #111111;
  font-size: 32rpx;
  font-weight: 800;
}

.activity-badge {
  display: inline-flex;
  align-self: flex-start;
  margin-bottom: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(10, 132, 255, 0.1);
  color: #0a84ff;
  font-size: 20rpx;
  font-weight: 700;
}

.activity-subtitle,
.activity-meta,
.activity-attendance,
.venue-meta,
.venue-vibe {
  color: rgba(17, 17, 17, 0.48);
  font-size: 24rpx;
  line-height: 1.5;
}

.activity-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(52, 199, 89, 0.12);
  color: #34c759;
  font-size: 20rpx;
  font-weight: 700;
}

.activity-status--warning {
  background: rgba(255, 159, 10, 0.12);
  color: #ff9f0a;
}

.activity-footer {
  align-items: center;
}

.activity-action {
  color: #0a84ff;
  font-size: 24rpx;
  font-weight: 800;
}

.venue-card {
  width: 460rpx;
  padding: 0;
  overflow: hidden;
}

.venue-cover {
  display: flex;
  gap: 8rpx;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(250, 250, 252, 1) 0%, rgba(241, 243, 247, 1) 100%);
}

.venue-name {
  color: #111111;
  font-size: 30rpx;
  font-weight: 800;
}

.venue-surface {
  color: #0a84ff;
  font-size: 22rpx;
  font-weight: 700;
}

.venue-body {
  display: flex;
  gap: 14rpx;
  padding: 28rpx;
}

.venue-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(238, 240, 244, 0.92);
  color: rgba(17, 17, 17, 0.72);
  font-size: 20rpx;
}

.card-hover {
  transform: scale(0.985);
  opacity: 0.92;
}

.chip-hover {
  opacity: 0.85;
}
