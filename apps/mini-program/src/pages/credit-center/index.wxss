.credit-page {
  gap: 24rpx;
  padding: 24rpx 24rpx 48rpx;
}

.hero-card,
.score-card,
.section-card,
.list-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid #dce2dd;
  background: #ffffff;
}

.hero-card {
  background: linear-gradient(180deg, #edf3ea 0%, #ffffff 100%);
}

.hero-eyebrow,
.score-level,
.list-status {
  color: #156b52;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title,
.section-title,
.list-title,
.score-value {
  color: #131714;
  font-weight: 800;
}

.hero-title {
  font-size: 42rpx;
  line-height: 1.3;
}

.hero-subtitle,
.section-subtitle,
.score-hint,
.score-meta,
.list-copy,
.list-time {
  color: #66726c;
  font-size: 24rpx;
  line-height: 1.6;
}

.score-value {
  font-size: 64rpx;
}

.section-header,
.list,
.reason-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reason-row {
  flex-direction: row;
  flex-wrap: wrap;
}

.reason-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dce2dd;
  background: #ffffff;
  color: #2d3631;
  font-size: 22rpx;
  font-weight: 700;
}

.reason-chip--active {
  border-color: #156b52;
  background: #156b52;
  color: #ffffff;
}

.textarea {
  min-height: 180rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid #dce2dd;
  color: #131714;
}

.submit-btn {
  border-radius: 999rpx;
  background: #156b52;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.list-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 16rpx;
}

.list-delta {
  color: #156b52;
  font-size: 24rpx;
  font-weight: 700;
}
